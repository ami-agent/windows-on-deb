#!/bin/bash
# Shared configuration — source this from scripts: source "$(dirname "$0")/config.env"

GAMES_DIR="$HOME/Games"
BNET_PREFIX="$GAMES_DIR/battlenet-prefix"
D2R_DATA_DIR="$GAMES_DIR/D2R"
BNET_INSTALL_DIR="$BNET_PREFIX/pfx/drive_c/Program Files (x86)/Battle.net"
BNET_LAUNCHER="$BNET_INSTALL_DIR/Battle.net Launcher.exe"
STEAM_ROOT="$HOME/.steam/root"
COMPAT_TOOLS_DIR="$STEAM_ROOT/compatibilitytools.d"

# Find installed GE-Proton by scanning compatibilitytools.d.
# Sets GE_PROTON_DIR if found, returns 1 otherwise.
find_ge_proton() {
    if [ ! -d "$COMPAT_TOOLS_DIR" ]; then
        return 1
    fi
    local dir
    for dir in "$COMPAT_TOOLS_DIR"/GE-Proton*/; do
        if [ ! -d "$dir" ]; then
            continue
        fi
        if [ ! -f "$dir/proton" ]; then
            continue
        fi
        local wine_binary="$dir/files/bin/wine"
        if [ -f "$wine_binary" ]; then
            if file "$wine_binary" 2>/dev/null | grep -q "x86-64"; then
                GE_PROTON_DIR="$dir"
                return 0
            fi
        fi
    done
    return 1
}

# Called by scripts that require GE-Proton. Exits if not found.
detect_ge_proton() {
    if ! find_ge_proton; then
        echo "ERROR: No GE-Proton installation found in $COMPAT_TOOLS_DIR"
        echo "Run 03-install-proton.sh first."
        exit 1
    fi
    echo "Found GE-Proton: $GE_PROTON_DIR"
}
